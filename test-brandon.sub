# test-brandon.sub
# Demonstrates run_as_owner: the job runs as domain user 'brandon',
# NOT as the HTCondor service account.
#
# Submit from ws-0 as brandon:
#   runas /user:FORTWOW\brandon cmd.exe
#   cd C:\HTCondorConfig
#   condor_submit test-brandon.sub

executable           = C:\HTCondorConfig\test-brandon.bat
universe             = vanilla

# run_as_owner: HTCondor fetches brandon's stored credential from the
# credd on mgr and impersonates brandon for the entire job process.
run_as_owner         = True

# Pin to our single execute node by FQDN
requirements         = (OpSys == "WINDOWS") && (Machine == "compute-0.fort.wow.dev")

# No file transfer — the batch file runs directly on the execute node.
# Output goes to the FSx share via UNC path in the batch script itself.
should_transfer_files = NO

# Local log/out/err on the execute node's local disk (visible via SSM)
output  = C:\HTCondorLogs\test-$(Process).out
error   = C:\HTCondorLogs\test-$(Process).err
log     = C:\HTCondorLogs\test.log

queue
